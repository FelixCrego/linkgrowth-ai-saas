# Public app URL (used for OAuth and Stripe redirects)
APP_URL="https://linkgrowth-ai-saas.vercel.app"

# Session signing key (use a long random string)
SESSION_SECRET="replace-with-long-random-secret"

# Neon Postgres connection string (include sslmode=require)
DATABASE_URL="postgresql://user:pass@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# OpenAI
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"

# LinkedIn OAuth
LINKEDIN_CLIENT_ID="YOUR_LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="YOUR_LINKEDIN_CLIENT_SECRET"
# Optional exact callback override. If set, this value is used as redirect_uri verbatim.
# LINKEDIN_REDIRECT_URI="https://linkgrowth-ai-saas.vercel.app/api/linkedin/callback"
# Optional additional scopes (comma or space-separated), e.g. r_member_profileAnalytics
# LINKEDIN_EXTRA_SCOPES="r_member_profileAnalytics"
# Optional LinkedIn version header used for REST analytics APIs (YYYYMM)
# LINKEDIN_API_VERSION="202605"

# Stripe
STRIPE_SECRET_KEY="sk_live_or_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_STARTER="price_starter_optional"
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_ELITE="price_xxx"
